{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Review Everything",
  "version": "0.10.0",
  "identifier": "com.pablosgraduation.review-everything-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Review Everything",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 500,
        "theme": "Dark",
        "backgroundColor": "#181818",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 14, "y": 22 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/difft"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
